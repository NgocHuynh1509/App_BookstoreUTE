g: 28,\r\n    shadowColor: \"#FF8BB3\",\r\n    shadowOpacity: 0.25,\r\n    shadowRadius: 12,\r\n    elevation: 8,\r\n    borderWidth: 2,\r\n    borderColor: \"#FFB6D9\",\r\n  },\r\n  title: {\r\n    fontSize: 26,\r\n    fontWeight: \"bold\",\r\n    textAlign: \"center\",\r\n    color: \"#FF4F9A\",\r\n    marginBottom: 5,\r\n  },\r\n  subtitle: {\r\n    textAlign: \"center\",\r\n    color: \"#D46A9E\",\r\n    marginBottom: 30,\r\n    fontSize: 15,\r\n  },\r\n  input: {\r\n    backgroundColor: \"#FFE6F2\",\r\n    borderRadius: 12,\r\n    padding: 15,\r\n    fontSize: 16,\r\n    marginBottom: 15,\r\n    borderWidth: 1,\r\n    borderColor: \"#FFB6D9\",\r\n    color: \"#D62478\",\r\n  },\r\n  button: {\r\n    backgroundColor: \"#FF5CA8\",\r\n    paddingVertical: 15,\r\n    borderRadius: 12,\r\n    alignItems: \"center\",\r\n    marginTop: 10,\r\n  },\r\n  buttonText: {\r\n    color: \"#fff\",\r\n    fontSize: 17,\r\n    fontWeight: \"bold\",\r\n  },\r\n  forgotText: {\r\n    textAlign: \"center\",\r\n    marginTop: 15,\r\n    color: \"#FF4F9A\",\r\n    fontSize: 14,\r\n    textDecorationLine: \"underline\",\r\n  },\r\n  footerText: {\r\n    textAlign: \"center\",\r\n    marginTop: 20,\r\n    color: \"#D46A9E\",\r\n    fontSize: 14,\r\n  },\r\n  link: {\r\n    color: \"#FF4F9A\",\r\n    fontWeight: \"bold\",\r\n    textDecorationLine: \"underline\",\r\n  },\r\n});
